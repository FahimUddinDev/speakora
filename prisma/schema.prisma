// This is your Prisma schema file
// SQLite for local development — change provider to "postgresql" for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  // level: "BEGINNER" | "INTERMEDIATE" | "ADVANCED"
  level         String         @default("BEGINNER")
  conversations Conversation[]
  mistakes      Mistake[]
  vocabulary    Vocabulary[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  // type: "CHAT" | "ROLEPLAY" | "VOICE"
  type      String    @default("CHAT")
  scenario  String?
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  // role: "USER" | "AI"
  role             String
  content          String
  correctedContent String?
  feedback         String?
  audioUrl         String?
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
}

model Mistake {
  id          String   @id @default(cuid())
  userId      String
  sentence    String
  correction  String
  explanation String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Vocabulary {
  id         String   @id @default(cuid())
  userId     String
  word       String
  suggestion String
  context    String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}
